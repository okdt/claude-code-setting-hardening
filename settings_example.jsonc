// Claude Code Setting Hardening Example
// Customize and copy to ~/.claude/settings.json (remove comments)
// See Claude_Code_Hardening_Cheat_Sheet.md for the rationale behind each rule.
// Sandbox: macOS (Seatbelt), Linux/WSL2 (bubblewrap). WSL1 not supported.
//
// Design principle: Sandbox first, permissions as complement.
// The sandbox (Layer 1) does the heavy lifting at the OS level.
// Deny rules below are either "Essential" (sandbox can't prevent)
// or "Defense in depth" (sandbox is primary, deny adds a second layer).
{
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "denyRead": ["~/.ssh", "~/.gnupg", "~/.aws", "~/.config/gcloud", "~/.bash_history", "~/.zsh_history"]
    }
  },
  "permissions": {
    // ── allow: skip permission prompts for trusted operations ──
    // Uncomment the rules you need. These are examples.
    // "allow": [
    //   // Test & Build
    //   "Bash(npm test *)",
    //   "Bash(npm run build *)",
    //   "Bash(npm run lint *)",
    //   "Bash(pytest *)",
    //   "Bash(go test *)",
    //   "Bash(cargo test *)",
    //   "Bash(make *)",
    //
    //   // Git (safe read-only operations)
    //   "Bash(git status *)",
    //   "Bash(git log *)",
    //   "Bash(git diff *)",
    //   "Bash(git branch *)",
    //
    //   // MCP read-only (allow reading, deny sending)
    //   "mcp__claude_ai_Slack__slack_list_channels",
    //   "mcp__claude_ai_Slack__slack_get_channel_history",
    //   "mcp__claude_ai_Slack__slack_get_thread_replies",
    //   "mcp__claude_ai_Slack__slack_get_users",
    //   "mcp__claude_ai_Slack__slack_search_messages",
    //   "mcp__claude_ai_Google_Calendar__gcal_list_events",
    //   "mcp__claude_ai_Google_Calendar__gcal_list_calendars",
    //   "mcp__claude_ai_Google_Calendar__gcal_get_event"
    // ],

    // ── ask: always prompt, even if previously approved (HITL checkpoint) ──
    // Uncomment the rules you need. These are examples.
    // "ask": [
    //   "Bash(git commit *)",
    //   "Bash(git push *)",
    //   "Bash(npm install *)",
    //   "Bash(pip install *)",
    //   "Bash(brew install *)",
    //   "Bash(psql *)",
    //   "Bash(mysql *)",
    //   "Bash(mongosh *)",
    //   "Bash(sqlite3 *)"
    // ],

    // ── deny: always block, regardless of context ──
    // Rules tagged [Essential] address threats sandbox can't prevent.
    // Rules tagged [Defense in depth] add a second layer where sandbox is primary.
    "deny": [
      // [Essential] Destructive git operations — sandbox allows CWD access
      "Bash(git push -f *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout .)",
      "Bash(git clean -f *)",
      "Bash(git add .)",
      "Bash(git add -A)",

      // [Defense in depth] Destructive file operations — sandbox limits scope
      "Bash(rm -rf *)",
      "Bash(rm -r *)",

      // [Defense in depth] Dangerous system operations — sandbox limits scope
      "Bash(chmod 777 *)",
      "Bash(chmod -R *)",
      "Bash(chown -R *)",
      "Bash(killall *)",
      "Bash(pkill *)",
      "Bash(kill -9 *)",
      // [Defense in depth] Privilege escalation — sandbox constrains scope
      "Bash(sudo *)",
      "Bash(su *)",

      // [Defense in depth] Remote code execution via pipe — sandbox blocks network
      "Bash(curl *|*sh)",
      "Bash(wget *|*sh)",

      // [Essential] macOS only — remove these if you're on Linux/Windows
      "Bash(open *)",
      "Bash(osascript *)",
      "Bash(defaults write *)",

      // [Defense in depth] Remote access — sandbox blocks network
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",

      // [Essential] Package publishing & deployment — sandbox can't prevent if network enabled
      "Bash(npm publish *)",
      "Bash(yarn publish *)",
      "Bash(pnpm publish *)",
      "Bash(*deploy*)",

      // [Essential] Infrastructure — sandbox partially covers, but credentials may be accessible
      "Bash(terraform apply *)",
      "Bash(terraform destroy *)",
      "Bash(kubectl apply *)",
      "Bash(kubectl delete *)",
      "Bash(helm install *)",
      "Bash(helm upgrade *)",
      "Bash(docker push *)",
      "Bash(aws * --no-cli-pager)",
      "Bash(gcloud * --quiet)",

      // [Defense in depth] Sensitive file access — sandbox limits filesystem scope
      "Read(**/.env)",
      "Read(**/.env.*)",

      // [Essential] MCP actions (sending) — sandbox can't prevent MCP tool calls
      "mcp__claude_ai_Slack__slack_send_message",
      "mcp__claude_ai_Slack__slack_schedule_message"
    ]
  }
}
